              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{audit_base}}/trips/{{trip_id}}", "host": ["{{audit_base}}"], "path": ["trips", "{{trip_id}}"] }
          }
        },
        {
          "name": "STEP 10 - Verify Driver Back to AVAILABLE",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Driver is AVAILABLE after completing trip', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.equal('AVAILABLE');",
                  "    pm.expect(json.future_trip_ids).to.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{driver_base}}/drivers/{{driver_id}}", "host": ["{{driver_base}}"], "path": ["drivers", "{{driver_id}}"] }
          }
        }
      ]
    }
