            "url": { "raw": "{{driver_base}}/drivers/{{driver_id}}/trips/{{trip_id}}/complete", "host": ["{{driver_base}}"], "path": ["drivers", "{{driver_id}}", "trips", "{{trip_id}}", "complete"] }
          }
        },
        {
          "name": "STEP 8 - Escort Completes Trip (triggers trip.completed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Escort marked trip complete', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    pm.expect(pm.response.json().message).to.equal('completed');",
                  "});",
                  "pm.test('After this step: check Kafdrop for trip.completed, then verify Trip Audit in STEP 9', function() {",
                  "    pm.expect(true).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{escort_base}}/escorts/{{escort_id}}/trips/{{trip_id}}/complete", "host": ["{{escort_base}}"], "path": ["escorts", "{{escort_id}}", "trips", "{{trip_id}}", "complete"] }
          }
        },
        {
          "name": "STEP 9 - Verify Trip Audit Record Written",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Audit record exists with COMPLETED outcome', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.outcome).to.equal('COMPLETED');",
