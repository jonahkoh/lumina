            "url": { "raw": "{{transport_base}}/transport/trips/{{trip_id}}/reaching", "host": ["{{transport_base}}"], "path": ["transport", "trips", "{{trip_id}}", "reaching"] }
          }
        },
        {
          "name": "STEP 7 - Driver Completes Trip",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Driver marked trip complete', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    pm.expect(pm.response.json().message).to.equal('completed');",
                  "});",
                  "pm.test('Check Kafdrop for trip.completed.driver (NOT trip.completed yet)', function() {",
