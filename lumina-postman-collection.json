            "url": { "raw": "{{escort_base}}/escorts", "host": ["{{escort_base}}"], "path": ["escorts"] }
          }
        },
        {
          "name": "STEP 3 - Submit Trip to Transport (starts matching)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Accepted 202 with matching_in_progress', function() {",
                  "    pm.expect(pm.response.code).to.equal(202);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.equal('matching_in_progress');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"trip_id\": \"{{trip_id}}\",\n  \"elderly_id\": \"{{elderly_id}}\",\n  \"caregiver_id\": \"{{caregiver_id}}\",\n  \"pickup_location\": { \"lat\": 1.35, \"lng\": 103.82 },\n  \"dropoff_location\": { \"lat\": 1.30, \"lng\": 103.85 },\n  \"appointment_datetime\": \"2026-06-09T10:00:00\",\n  \"mobility_flags\": [],\n  \"elderly_needs\": [],\n  \"preferred_languages\": [\"english\"],\n  \"service_area\": \"Yishun\"\n}"
            },
            "url": { "raw": "{{transport_base}}/transport/trips", "host": ["{{transport_base}}"], "path": ["transport", "trips"] }
          }
        },
        {
          "name": "STEP 3b - Check Kafdrop for trip.offered.driver and trip.offered.escort",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:9000", "host": ["http://localhost:9000"], "path": [] },
            "description": "Open http://localhost:9000 in browser. Look for topics: trip.requested, trip.offered.driver, trip.offered.escort. Messages should appear within ~2 seconds of Step 3."
          }
        },
        {
          "name": "STEP 4 - Driver Accepts Trip",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Driver accepted trip', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    pm.expect(pm.response.json().message).to.equal('accepted');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{driver_base}}/drivers/{{driver_id}}/trips/{{trip_id}}/accept", "host": ["{{driver_base}}"], "path": ["drivers", "{{driver_id}}", "trips", "{{trip_id}}", "accept"] }
          }
        },
        {
          "name": "STEP 5 - Escort Accepts Trip",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Escort accepted trip', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    pm.expect(pm.response.json().message).to.equal('accepted');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{escort_base}}/escorts/{{escort_id}}/trips/{{trip_id}}/accept", "host": ["{{escort_base}}"], "path": ["escorts", "{{escort_id}}", "trips", "{{trip_id}}", "accept"] }
          }
