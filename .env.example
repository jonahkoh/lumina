# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Local (docker compose):  POSTGRES_HOST=localhost  (port-forwarded 5432)
# Cloud SQL Auth Proxy:    POSTGRES_HOST=127.0.0.1  (proxy tunnels to Cloud SQL)
# GKE sidecar proxy:       POSTGRES_HOST=/cloudsql/<project>:<region>:<instance>
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Kafka ───────────────────────────────────────────────────────────────────
# Local (docker compose):  KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Confluent Cloud (GKE):   change to <bootstrap>.confluent.cloud:9092
#                          and uncomment KAFKA_API_KEY / KAFKA_API_SECRET
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_API_KEY=
# KAFKA_API_SECRET=

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local (docker compose):  REDIS_URL=redis://localhost:6379/0
# Cloud Memorystore (GKE): REDIS_URL=redis://<private-ip>:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── Google Cloud (uncomment when migrating to GKE) ──────────────────────────
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=
